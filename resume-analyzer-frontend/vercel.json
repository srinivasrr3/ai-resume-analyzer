{
  "version": 2,
  "buildCommand": "npm ci && npm run build",
  "outputDirectory": "dist/resume-analyzer-frontend/browser",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://ai-resume-analyzer-pypx.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
